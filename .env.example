# 邮件配置（用于发送结果）
# 请将本文件复制为 .env 并填入真实配置

# QQ邮箱示例
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
SENDER_EMAIL=your_qq@qq.com
SENDER_PASSWORD=你的QQ邮箱授权码

# 163邮箱示例
# SMTP_SERVER=smtp.163.com
# SMTP_PORT=465
# SENDER_EMAIL=your_email@163.com
# SENDER_PASSWORD=你的163邮箱授权码

# 企业邮箱示例
# SMTP_SERVER=smtp.yourcompany.com
# SMTP_PORT=587
# SENDER_EMAIL=your_email@yourcompany.com
# SENDER_PASSWORD=你的邮箱密码